# Ejemplo de variables de entorno — copiar a .env y completar

# Base de datos
POSTGRES_DB=uniform
POSTGRES_USER=uniform
POSTGRES_PASSWORD=cambiar_esto_por_password_seguro

# Seguridad JWT — generar con: openssl rand -hex 32
SECRET_KEY=cambiar_esto_por_clave_secreta_muy_larga
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin inicial (se crea automáticamente al primer arranque)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=Admin@12345!
FIRST_ADMIN_FIRST_NAME=Administrador
FIRST_ADMIN_LAST_NAME=Sistema

# CORS — dominio(s) del frontend separados por coma
CORS_ORIGINS=https://form.tu-emprendimiento.tech

# Archivos adjuntos
MAX_UPLOAD_SIZE_MB=10

# Frontend (usado en build de Docker)
VITE_API_URL=https://form.tu-emprendimiento.tech/api
